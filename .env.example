# Configure estas variáveis no Vercel (Project Settings → Environment Variables)
# e localmente em um arquivo .env (que NÃO vai pro Git).

# Supabase
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Senha de acesso padrão (opcional — default: gestao123)
VITE_STORE_PASSWORD=gestao123
